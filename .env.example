# ============================================================
# Decentralized AI Content Moderation — Environment Variables
# Copy this file to .env in each node directory and fill in values.
# ============================================================

# ── PORT ASSIGNMENTS ─────────────────────────────────────────
FRONTEND_PORT=3000
INGESTION_PORT=3001
AI_PORT=3002
HUMAN_PORT=3003
STORAGE_PORT=3004

# ── AZURE QUEUE STORAGE (Cloud 1) ────────────────────────────
# Get from: Azure Portal → Storage Account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net

# ── AWS REKOGNITION (Cloud 2) ────────────────────────────────
# Get from: AWS IAM → Create User → Attach AmazonRekognitionFullAccess policy
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── GOOGLE PERSPECTIVE API (Cloud 3) ─────────────────────────
# Get from: https://developers.perspectiveapi.com/s/docs-get-started
PERSPECTIVE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── IPFS / PINATA ────────────────────────────────────────────
# Get from: https://app.pinata.cloud/developers/api-keys
# Create a key with the pinFileToIPFS permission, then copy the JWT.
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_YOUR_PINATA_JWT_HERE

# ── CONFIDENCE THRESHOLDS ────────────────────────────────────
THRESHOLD_AUTO_APPROVE=0.85
THRESHOLD_AUTO_REJECT=0.85
THRESHOLD_GRAY_LOW=0.40
