# ============================================================
# Decentralized AI Content Moderation — Environment Variables
#
# Copy this file to .env in each node directory and replace the
# placeholder values below with credentials issued by your own
# cloud accounts. The placeholders use the canonical example
# formats documented by each provider — they will not authenticate.
# ============================================================

# ── PORT ASSIGNMENTS ─────────────────────────────────────────
FRONTEND_PORT=3000
INGESTION_PORT=3001
AI_PORT=3002
HUMAN_PORT=3003
STORAGE_PORT=3004

# ── AZURE QUEUE STORAGE (Cloud 1 of 3) ───────────────────────
# Portal → Storage Account → Security + networking → Access keys
# → Connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_STORAGE_ACCOUNT;AccountKey=EXAMPLE_AZURE_STORAGE_ACCOUNT_KEY_BASE64_REPLACE_ME==;EndpointSuffix=core.windows.net

# ── AWS REKOGNITION (Cloud 2 of 3) ───────────────────────────
# IAM → Users → Create user → Attach AmazonRekognitionFullAccess
# → Security credentials → Create access key
# (values below are AWS's documented example credentials)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── GOOGLE PERSPECTIVE API (Cloud 3 of 3) ────────────────────
# https://developers.perspectiveapi.com/s/docs-get-started
# Cloud Console → APIs & Services → Credentials → Create API key
PERSPECTIVE_API_KEY=AIzaSyEXAMPLE_REPLACE_WITH_YOUR_PERSPECTIVE_KEY

# ── IPFS / PINATA (Decentralized Storage) ────────────────────
# https://app.pinata.cloud/developers/api-keys → New Key
# (enable pinFileToIPFS scope, then copy the JWT)
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_YOUR_PINATA_JWT_PAYLOAD.REPLACE_WITH_YOUR_PINATA_JWT_SIGNATURE

# ── CONFIDENCE THRESHOLDS (Human-in-the-Loop) ────────────────
THRESHOLD_AUTO_APPROVE=0.85
THRESHOLD_AUTO_REJECT=0.85
THRESHOLD_GRAY_LOW=0.40
